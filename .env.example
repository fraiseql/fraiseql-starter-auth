# .env.example — Environment variable template for the FraiseQL auth starter
#
# Copy this file to .env and fill in values before running:
#   cp .env.example .env
#
# NEVER commit .env to source control. It is already listed in .gitignore.

# ----------------------------------------------------------------------------
# Database
#
# PostgreSQL connection string. Matches docker-compose.yml defaults.
# For production, use a managed service (RDS, Cloud SQL, etc.) with SSL.
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://fraiseql:dev_password_change_in_prod@localhost:5432/fraiseql_auth

# ----------------------------------------------------------------------------
# JWT Secret (local development and tests only)
#
# Used by tests/conftest.py to mint HS256 JWTs for integration tests.
# In production, FraiseQL validates JWTs against your OIDC provider's JWKS
# endpoint (RS256 / ES256) — this variable is not used at runtime.
#
# Generate a value: openssl rand -base64 32
# ----------------------------------------------------------------------------
JWT_SECRET=dev-jwt-secret-replace-in-production-with-32-random-bytes

# ----------------------------------------------------------------------------
# Optional: PKCE / OIDC
#
# Only required when enabling server-managed auth routes (/auth/start,
# /auth/callback). Set enabled = true in [security.pkce] and
# [security.state_encryption] in fraiseql.toml before setting these.
#
# OIDC_CLIENT_SECRET=your-oidc-client-secret
# FRAISEQL_STATE_ENCRYPTION_KEY=   # generate: openssl rand -hex 32
# ----------------------------------------------------------------------------
